	-- NOTIFICATION
	------------------------------------------------
	local function notif(str,dur)
		game:GetService("StarterGui"):SetCore("SendNotification", {
			Title = "Spectate GUI",
			Text = str,
			Icon = "rbxassetid://0",
			Duration = dur or 3
		})
	end
	
