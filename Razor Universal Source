-- StarterPack.Razor Universal.Initialization Script
local function C_2()
local script = G2L["2"];
	local Players = game:GetService("Players")
	local StarterGui = game:GetService("StarterGui")
	
	local player = Players.LocalPlayer
	local root = script.Parent
	
	local loading = true
	
	------------------------------------------------
	-- NOTIFY
	------------------------------------------------
	local function notify(title, text)
		pcall(function()
			StarterGui:SetCore("SendNotification", {
				Title = title,
				Text = text,
				Button1 = "Okay",
				Duration = 5
			})
		end)
	end
	
	------------------------------------------------
	-- KICK (ONLY DURING LOADING)
	------------------------------------------------
	local function kick()
		if loading then
			player:Kick("Please wait for the client to fully load and initialize before you go on a joyride.")
		end
	end
	
	------------------------------------------------
	-- START MESSAGE
	------------------------------------------------
	notify(
		"Razor Universal Client",
		"Loading Client... (DO NOT USE CLIENT BEFORE LOADING IS COMPLETE)"
	)
	
	------------------------------------------------
	-- HOOK INTERACTIONS (SAFE WRAPPED)
	------------------------------------------------
	local function hook(inst)
		if not loading then return end
	
		pcall(function()
	
			if inst:IsA("Tool") then
				inst.Activated:Connect(function()
					if loading then kick() end
				end)
	
				inst.Equipped:Connect(function()
					if loading then kick() end
				end)
			end
	
			if inst:IsA("ClickDetector") then
				inst.MouseClick:Connect(function()
					if loading then kick() end
				end)
			end
	
			if inst:IsA("ProximityPrompt") then
				inst.Triggered:Connect(function()
					if loading then kick() end
				end)
			end
	
			if inst:IsA("GuiButton") then
				inst.MouseButton1Click:Connect(function()
					if loading then kick() end
				end)
			end
	
			if inst:IsA("RemoteEvent") then
				inst.OnClientEvent:Connect(function()
					if loading then kick() end
				end)
			end
	
		end)
	end
	
	------------------------------------------------
	-- INITIAL SCAN
	------------------------------------------------
	for _, obj in ipairs(root:GetDescendants()) do
		hook(obj)
	end
	
	root.DescendantAdded:Connect(hook)
	
	------------------------------------------------
	-- END LOADING PHASE
	------------------------------------------------
	task.wait(6)
	
	loading = false
	
	notify(
		"Razor Universal Client",
		"Client Loaded Successfully, You may now use the client without worry"
	)
end;
task.spawn(C_2);
