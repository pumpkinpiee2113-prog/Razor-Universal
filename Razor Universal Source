	local currentTarget = nil
	local camera = workspace.CurrentCamera
	
	TextButton.MouseButton1Click:Connect(function()
	
		-- STOP SPECTATING
		if spectating then
			spectating = false
			currentTarget = nil
	
			if lp.Character and lp.Character:FindFirstChildWhichIsA("Humanoid") then
				camera.CameraSubject = lp.Character:FindFirstChildWhichIsA("Humanoid")
			end
	
			notif("Stopped spectating")
			return
		end
	
		local input = TextBox.Text:lower()
	
		-- 🚫 Block invalid inputs
		if input == "all" or input == "others" or input == "" then
			notif("Enter a single player name")
			return
		end
	
		-- Find players
		local TargetList = gplr(TextBox.Text)
	
		-- 🚫 Prevent multiple targets
		if #TargetList > 1 then
			notif("Multiple players found, be more specific")
			return
		end
	
		if TargetList[1] then
			local Target = TargetList[1]
			currentTarget = Target
			spectating = true
	
			notif("Spectating " .. Target.Name)
	
			task.spawn(function()
				while spectating and currentTarget do
					local char = currentTarget.Character
					local hum = char and char:FindFirstChildWhichIsA("Humanoid")
	
					if hum then
						camera.CameraSubject = hum
					else
						notif("Target lost")
						spectating = false
						break
					end
	
					task.wait(0.2)
				end
	
				-- Reset camera
				if lp.Character and lp.Character:FindFirstChildWhichIsA("Humanoid") then
					camera.CameraSubject = lp.Character:FindFirstChildWhichIsA("Humanoid")
				end
			end)
	
		else
			notif("Player not found")
		end
	end)
