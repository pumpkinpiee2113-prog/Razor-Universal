local function C_2f()
local script = G2L["2f"];
	local button = script.Parent
	local textBox = button:FindFirstChild("TextBox") or button.Parent:FindFirstChild("TextBox")
	
	local Players = game:GetService("Players")
	local RunService = game:GetService("RunService")
	local localPlayer = Players.LocalPlayer
	
	local function stopMovement(connection, bodyPos)
		if connection then connection:Disconnect() end
		if bodyPos and bodyPos.Parent then bodyPos:Destroy() end
	end
	
	button.MouseButton1Click:Connect(function()
		local targetName = textBox.Text
		local target = Players:FindFirstChild(targetName)
		if not target or not target.Character then
			warn("Player not found: " .. targetName)
			return
		end
	
		local char = localPlayer.Character
		local hrp = char and char:FindFirstChild("HumanoidRootPart")
		if not hrp then return end
	
		local targetHRP = target.Character:FindFirstChild("HumanoidRootPart")
		if not targetHRP then return end
	
		-- List tools in backpack
		local tools = {}
		local backpack = localPlayer.Backpack
		for _, item in ipairs(backpack:GetChildren()) do
			if item:IsA("Tool") then
				table.insert(tools, item.Name)
			end
		end
	
		if #tools == 0 then
			warn("No tools in backpack")
			return
		end
	
		-- Ask which tool to use
		local toolName = nil
		if #tools == 1 then
			toolName = tools[1]
		else
			-- Simple prompt using a dialog or just pick first
			-- In a real scenario you'd use a GUI, but here we use the first tool
			toolName = tools[1]
		end
	
		-- Equip the tool
		local tool = backpack:FindFirstChild(toolName)
		if tool then
			local humanoid = char and char:FindFirstChild("Humanoid")
			if humanoid then
				humanoid:EquipTool(tool)
			end
		end
	
		local bodyPos = Instance.new("BodyPosition")
		bodyPos.MaxForce = Vector3.new(10000, 10000, 10000)
		bodyPos.P = 3000
		bodyPos.D = 50
		bodyPos.Position = targetHRP.Position + Vector3.new(0, 3, 0)
		bodyPos.Parent = hrp
	
		local connection
		connection = RunService.Heartbeat:Connect(function()
			targetHRP = target.Character and target.Character:FindFirstChild("HumanoidRootPart")
			if not targetHRP or not hrp.Parent then
				stopMovement(connection, bodyPos)
				return
			end
			bodyPos.Position = targetHRP.Position + Vector3.new(0, 3, 0)
			if (hrp.Position - targetHRP.Position).Magnitude < 4 then
				stopMovement(connection, bodyPos)
			end
		end)
	
		task.delay(10, function()
			stopMovement(connection, bodyPos)
		end)
	end)
end;
