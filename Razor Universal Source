	-- TOGGLE
	------------------------------------------------
	button.MouseButton1Click:Connect(function()
		enabled = not enabled
	
		if enabled then
			for _, p in ipairs(Players:GetPlayers()) do
				if p.Character then
					createESP(p, p.Character)
				end
			end
		else
			clearESP()
		end
	end)
