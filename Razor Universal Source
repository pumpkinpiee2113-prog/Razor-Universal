	local button = script.Parent
	local textBox = button:WaitForChild("TextBox")
	
	local Players = game:GetService("Players")
	local lp = Players.LocalPlayer
	
	------------------------------------------------
	-- NOTIFICATION FUNCTION
	------------------------------------------------
	local function notif(title, text, duration)
		game:GetService("StarterGui"):SetCore("SendNotification", {
			Title = title or "Teleport",
			Text = text or "",
			Duration = duration or 3
		})
	end
	
	------------------------------------------------
	-- PARSE "x,y,z"
	------------------------------------------------
	local function parseVector3(text)
		local x, y, z = text:match("([^,]+),([^,]+),([^,]+)")
		if not x or not y or not z then return nil end
	
		x, y, z = tonumber(x), tonumber(y), tonumber(z)
	
		if not x or not y or not z then
			return nil
		end
	
		return Vector3.new(x, y, z)
	end
	
	------------------------------------------------
	-- TELEPORT PLAYER
	------------------------------------------------
	local function teleport(pos)
		local char = lp.Character
		if not char then
			notif("Error", "Character not loaded")
			return
		end
	
		local root = char:FindFirstChild("HumanoidRootPart")
		if not root then
			notif("Error", "HumanoidRootPart missing")
			return
		end
	
		root.CFrame = CFrame.new(pos)
		notif("Success", "Teleported successfully")
	end
	
	------------------------------------------------
	-- BUTTON CLICK
	------------------------------------------------
	button.MouseButton1Click:Connect(function()
		local pos = parseVector3(textBox.Text)
	
		if not pos then
			notif("Invalid Input", "Use format: x,y,z (example: 0,10,0)")
			return
		end
	
		teleport(pos)
	end)
