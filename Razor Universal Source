	local StarterGui = game:GetService("StarterGui")
	
	-- hidden textbox (for Ctrl+C fallback)
	local copyBox = Instance.new("TextBox")
	copyBox.Size = UDim2.new(0, 0, 0, 0)
	copyBox.Position = UDim2.new(-1000, 0, -1000, 0)
	copyBox.BackgroundTransparency = 1
	copyBox.TextTransparency = 1
	copyBox.ClearTextOnFocus = false
	copyBox.Parent = button.Parent
	
	local function notify(title, text)
		pcall(function()
			StarterGui:SetCore("SendNotification", {
				Title = title,
				Text = text,
				Duration = 2
			})
		end)
	end
	
	button.MouseButton1Click:Connect(function()
		local codeToCopy = "https://discord.gg/pYs3T7NaY6"
	
		-- put text into hidden box
		copyBox.Text = codeToCopy
		copyBox:CaptureFocus()
	
		task.wait()
	
		copyBox.SelectionStart = 1
		copyBox.CursorPosition = #copyBox.Text + 1
	
		-- CoreGui notification (real Roblox system UI)
		notify("Discord", "Press Ctrl + C to copy")
	end)
end;
task.spawn(C_b4);

return G2L["1"], require;
