	local UserInputService = game:GetService("UserInputService")
	
	local xray = false
	local originalTransparency = {}
	
	------------------------------------------------
	-- CHECK IF PART BELONGS TO CHARACTER
	------------------------------------------------
	local function isCharacterPart(obj)
		local model = obj:FindFirstAncestorOfClass("Model")
		if not model then return false end
		if not model:FindFirstChildOfClass("Humanoid") then return false end
		return true
	end
	
	------------------------------------------------
	-- APPLY XRAY EFFECT
	------------------------------------------------
	local function apply(obj)
		if not obj:IsA("BasePart") then return end
		if isCharacterPart(obj) then return end
	
		if originalTransparency[obj] == nil then
			originalTransparency[obj] = obj.Transparency
		end
	
		-- NEW: keep fully transparent parts untouched
		if originalTransparency[obj] == 1 then return end
	
		if xray then
			obj.Transparency = 0.5
			obj.CastShadow = false
		else
			local original = originalTransparency[obj]
			if original ~= nil then
				obj.Transparency = original
			end
			obj.CastShadow = true
		end
	end
	
	------------------------------------------------
	-- REFRESH WORLD
	------------------------------------------------
	local function refresh()
		for _, obj in ipairs(workspace:GetDescendants()) do
			apply(obj)
		end
	end
	
	------------------------------------------------
	-- HANDLE NEW PARTS
	------------------------------------------------
	workspace.DescendantAdded:Connect(function(obj)
		task.defer(function()
			apply(obj)
		end)
	end)
	
	workspace.DescendantRemoving:Connect(function(obj)
		originalTransparency[obj] = nil
	end)
	
	------------------------------------------------
	-- UPDATE BUTTON TEXT
	------------------------------------------------
	local function updateText()
