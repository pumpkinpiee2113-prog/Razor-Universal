	local enabled = false
	local billboards = {}
	local boxes = {}
	local connections = {}
	
	------------------------------------------------
	-- FORMAT NAME
	------------------------------------------------
	local function formatText(text, isUsername)
		if isUsername then return text end
	
		return text:gsub("(%a)([%w_']*)", function(first, rest)
			return first:upper() .. rest:lower()
		end)
	end
	
	------------------------------------------------
	-- CREATE ESP
	------------------------------------------------
	local function createESP(player, character)
		if billboards[player] then return end
	
		local head = character:WaitForChild("Head")
		local humanoid = character:WaitForChild("Humanoid")
	
		------------------------------------------------
		-- FIND TORSO (R6 / R15)
		------------------------------------------------
		local hrp = character:FindFirstChild("HumanoidRootPart")
		local torso = character:FindFirstChild("Torso")
		local upper = character:FindFirstChild("UpperTorso")
	
		local attachPart = hrp or upper or torso
		if not attachPart then return end
	
		------------------------------------------------
		-- TORSO BOX (TRUE ESP STYLE)
		------------------------------------------------
		local box = Instance.new("BoxHandleAdornment")
		box.Name = "TorsoBox"
		box.Adornee = attachPart
		box.AlwaysOnTop = true
		box.ZIndex = 5
		box.Size = Vector3.new(
			attachPart.Size.X * 1.25,
			attachPart.Size.Y * 1.25,
			attachPart.Size.Z * 1.25
		)
		box.Transparency = 0.5
	
		-- TEAM COLOR OR WHITE
		if player.Team and player.Team.TeamColor then
			box.Color3 = player.Team.TeamColor.Color
		else
			box.Color3 = Color3.new(1,1,1)
		end
	
		box.Parent = attachPart
		boxes[player] = box
	
		------------------------------------------------
		-- NAME UI
		------------------------------------------------
		local gui = Instance.new("BillboardGui")
		gui.Name = "ESP_UI"
		gui.Size = UDim2.new(0, 250, 0, 25)
		gui.StudsOffset = Vector3.new(0, 2.7, 0)
		gui.AlwaysOnTop = true
		gui.Parent = head
	
		local label = Instance.new("TextLabel")
		label.Size = UDim2.new(1, 0, 1, 0)
		label.BackgroundTransparency = 1
		label.TextScaled = true
		label.Font = Enum.Font.Arimo
		label.TextColor3 = Color3.new(1,1,1)
		label.TextStrokeTransparency = 0
		label.Parent = gui
	
		billboards[player] = label
	
		------------------------------------------------
		-- LIVE UPDATE
		------------------------------------------------
		connections[player] = RunService.RenderStepped:Connect(function()
			if not enabled then return end
			if not character.Parent then return end
	
			local myChar = localPlayer.Character
			if not myChar then return end
	
			local myRoot = myChar:FindFirstChild("HumanoidRootPart")
			local targetRoot = character:FindFirstChild("HumanoidRootPart")
	
			local hp = humanoid and math.floor(humanoid.Health) or 0
			local dist = 0
	
			if myRoot and targetRoot then
				dist = math.floor((myRoot.Position - targetRoot.Position).Magnitude)
			end
	
			label.Text = string.format("%s | Hp: %d | Dist: %d",
				formatText(player.Name, true),
				hp,
				dist
